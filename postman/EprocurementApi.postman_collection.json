  "info": {
    "_postman_id": "d28f4d33-bb5c-49fc-8ad2-4c8f797cdb31",
    "name": "Eprocurement API - Full Flow",
    "description": "Complete collection to demonstrate the E-Procurement project (Auth, User, Supplier, PurchaseRequest, and PurchaseOrder).\n\nCollection variables:\n- baseUrl: API URL\n- token: Login JWT\n- supplierId: Created supplier ID\n- purchaseRequestId: Created purchase request ID\n- purchaseOrderId: Created purchase order ID\n\nRecommended execution order:\n1) User > Register (Admin/Manager/Procurement/Employee)\n2) Auth > Login\n3) Supplier > Register\n4) Purchase Request > Create\n5) Purchase Request > Approve\n6) Purchase Request > Move To Procurement\n7) Purchase Order > Create\n8) Purchase Order > Send / Complete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
